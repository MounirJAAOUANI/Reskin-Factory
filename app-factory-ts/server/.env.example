# Core
NODE_ENV=production
PORT=4000
MODE_ENV=development
# Set to "production" to enable real API calls; "development" returns simulated data

# CORS
FRONTEND_URL=http://localhost:5173

# Redis (optional — falls back to jobs.json)
REDIS_URL=redis://:localpassword@localhost:6379

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_REPO_OWNER=myusername
GITHUB_REPO_NAME=app-factory-builds
GITHUB_PAGES_REPO=myusername/myusername.github.io

# Google Play Console
# Paste the full JSON content of your service account key here (inline, JSON-encoded as string)
GOOGLE_PLAY_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
GOOGLE_PLAY_PACKAGE_ID=com.myapp.example

# Firebase
FIREBASE_PROJECT_ID=myproject
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@myproject.iam.gserviceaccount.com

# Password protection (production only)
# Leave empty in development
PASSWORD_HASH=
# SHA-256 hex of the access password, e.g.: echo -n "mypassword" | sha256sum
